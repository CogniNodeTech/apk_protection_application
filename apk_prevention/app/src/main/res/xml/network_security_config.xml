<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext disabled; trust system CAs. Pinning is additionally enforced in OkHttp when CERT_PIN is set. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
