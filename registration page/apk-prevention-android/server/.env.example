# Copy to .env and adjust. Never commit .env.

# Option A: single URL (recommended for production with SSL)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/apk_prevention?sslmode=prefer

# Option B: discrete variables (local development)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=apk_prevention

# Use true when connecting to managed Postgres (RDS, Azure, etc.)
PGSSL=false
# Set to false only if using self-signed certs in dev
# PGSSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
OTP_PEPPER=CHANGE_ME_OTP_PEPPER_LONG_RANDOM
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- SMS (Twilio) — required in production for OTP delivery ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional: default country code when phone has no + (e.g. 91 for India)
SMS_DEFAULT_COUNTRY_CODE=91

# --- Google Sign-In (Android uses Web client ID as server audience) ---
GOOGLE_CLIENT_ID=

# --- Facebook Login ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Sign in with Apple ---
# Service ID (web) or bundle id; must match Android app authorize URL client_id
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM contents with \n for newlines, or use APPLE_PRIVATE_KEY_PATH
APPLE_PRIVATE_KEY=
# APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8
# Must match the redirect URL used by the Android app and Apple Developer Return URLs
APPLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/apple/callback
# Optional: public base URL if APPLE_REDIRECT_URI is not set (constructed as PUBLIC_BASE_URL + /api/auth/oauth/apple/callback)
PUBLIC_BASE_URL=https://your-domain.com
# Deep link scheme for Android after Apple web callback (default com.apkprevention.auth)
OAUTH_ANDROID_APP_SCHEME=com.apkprevention.auth

# --- Password reset email (SMTP) ---
# If NODE_ENV=production, this must be configured for forgot-password to actually deliver emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="APK Prevention <no-reply@your-domain.com>"
# URL users open from email. Token will be appended as ?token=...
# Example web page: https://your-domain.com/reset-password
PASSWORD_RESET_BASE_URL=
APP_NAME=APK Prevention
